# Alias LARAVEL
alias laravel='$HOME/.config/composer/vendor/bin/laravel'

alias ls='ls --color=auto --group-directories-first'
alias lsa='ls -a -h --color=auto --group-directories-first'
alias ll='ls -l --color=auto --group-directories-first'
alias lla='ls -l -a -h --color=auto --group-directories-first'

alias zshcon="vim ~/.zshrc"
alias vimcon="vim ~/.vimrc"

alias grep='grep --colour=auto'
alias egrep='egrep --colour=auto'
alias fgrep='fgrep --colour=auto'

alias cp="cp -i -v"	# подтвердите, прежде чем перезаписывать что-либо
alias mv="mv -i -v"	# Выводить информацию о каждом файле, который обрабатывает команда mv
alias rm="rm -I -v -f"
alias md="mkdir"

alias c='clear'
alias ln='ln -s'
alias sshadd='eval $(ssh-agent) && ssh-add ~/.ssh/id_rsa'
alias cdm='cd /run/media/notebook/MEDIA/'

# Pacman
alias spu='sudo pacman -Syu'
alias spi='sudo pacman -S'
alias spr='sudo pacman -R'
alias sprns='sudo pacman -Rns'

# YAY
alias yi='yay -S --noconfirm'
alias yu='yay -Syu'
alias yr='yay -R'

# Trizen
alias ti='trizen -S --noconfirm'
alias tu='trizen -Syu'
alias tr='trizen -R'

# Pikaur
alias pi='pikaur -S --noedit'
alias pu='pikaur -Syu'
alias pr='pikaur -R'

# Mikrotik
alias mikrotikreboot="ssh roman@192.168.88.1 reboot system"
alias mikrotikopen="ssh roman@192.168.88.1"

# Ping
alias ping='ping -c 4'

