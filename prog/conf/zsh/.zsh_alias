alias ga='git add .'
# alias gitc='git commit -m "add"'
# alias gc='git commit -m "add"'
gitc() {
  if [[ -z "$1" ]] ; then
    com='"add"'
  else
    com='"'"$@"'"'
  fi
  git commit -m "$com"
}
gc() {
  if [[ -z "$1" ]] ; then
    com='"add"'
  else
    com='"'"$@"'"'
  fi
  git commit -m $com
}
alias gitp='git push'
alias gp='git push'

