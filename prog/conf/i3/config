exec_always --no-startup-id picom --experimental-backends -b --backend glx --vsync --xrender-sync-fence --glx-no-rebind-pixmap --use-damage --glx-no-stencil --config $HOME/.config/picom/picom.conf
#exec_always --no-startup-id picom --experimental-backends -b --config $HOME/.config/picom/picom.conf
#exec_always --no-startup-id picom -b
