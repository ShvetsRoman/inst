exec --no-startup-id numlockx on
# Touchpad OFF
exec --no-startup-id xinput disable 18
# Language
exec "setxkbmap -model pc104 -layout us,ru,ua -variant ,, -option grp:alt_shift_toggle"
# Automount USB
exec --no-startup-id udiskie
# Cursor
exec --no-startup-id xsetroot -cursor_name left_ptr
# terminal
exec --no-startup-id $terminal
# Browser
#exec --no-startup-id $browser 
####################################

bindsym $mod + F1 exec $browser 
bindsym $mod + F2 exec $fileManager 
