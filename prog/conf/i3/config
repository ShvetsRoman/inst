# Media player controls
bindsym XF86AudioPlay exec playerctl --all-players play-pause
bindsym XF86AudioNext exec playerctl --all-players next
bindsym XF86AudioPrev exec playerctl --all-players previous
bindsym XF86AudioStop exec playerctl --all-players stop

# Sreen brightness controls
bindsym XF86MonBrightnessUp exec xbacklight -inc 20 # increase screen brightness
bindsym XF86MonBrightnessDown exec xbacklight -dec 20 # decrease screen ndbrightness

# betterlockscreen
bindsym XF86ScreenSaver exec betterlockscreen -l blur
bindsym $mod+shift+x exec betterlockscreen -l blur
#exec --no-startup-id xautolock -time 15 -locker 'betterlockscreen -l blur' -detectsleep
#exec --no-startup-id xautolock -time 30 -locker "systemctl suspend" &

# Touchpad OFF
bindsym XF86TouchpadToggle exec "~/.config/i3/scripts/touchpad_toggle.sh"

# screenshot
bindsym --release $mod+z exec scrot -s 

# КНОПКИ УПРАВЛЕНИЯ ГРОМКОСТЬЮ ДЛЯ ПУЛЬСАУДИО
