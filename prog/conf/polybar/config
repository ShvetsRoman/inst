[colors]
bg = #11121D
bg-alt = #20212C 
fg = #acb0d0 
fg-alt = #5D5E72 

red = #ff7a93 

trans = #00000000
semi-trans-black = #CC000000

shade-1 = #32344a
;shade-2 = #444b6a
shade-3 = #787c99
;shade-4 = #CACACE
shade-5 = #acb0d0

[bar/bar1]
width = 100%
height = 20
offset-y = 0
top = true
fixed-center = true
 
wm-restack = i3
override-redirect = false

scroll-up = next
scroll-down = prev

enable-ipc = true

background = ${colors.bg}
foreground = ${colors.fg}

padding-left = 2
padding-right = 2
module-margin-left = 1
module-margin-right = 0

font-0 = "JetBrains Mono Nerd Font:style=Medium:size=10;2"
font-1 = "JetBrains Mono Nerd Font:style=Bold:size=10;2"
font-2 = "JetBrains Mono Nerd Font:size=19;5"
font-3 = "Material Icons Outlined:9;4"
font-4 = "Material Icons Round:9;4"
font-5 = "Source Han Sans CN:size=9;2"

modules-left = apps i3
modules-center =
modules-right = updates-pacman-aur wlan2 eth battery pulseaudio xkeyboard date session

cursor-click = pointer

[module/title]
type = internal/xwindow

format = <label>
format-background = ${colors.bg}
format-foreground = ${colors.fg} 
format-padding = 1

label = %title%
label-maxlen = 40

[module/updates-pacman-aur]
type = custom/script
exec = $HOME/.config/polybar/scripts/updates-pacman-aur.sh
interval = 300
format-foreground = ${colors.fg}
click-left = sh $HOME/.config/polybar/scripts/up_system.sh

; Put this module on your polybar config, make sure enable-ipc=true
[module/dunst]
type = custom/ipc
initial = 1
format-foreground-1 = ${colors.red}
hook-0 = echo "%{A1:"dunstctl set-paused true" && polybar-msg hook dunst 2:}пѓі%{A}" &
hook-1 = echo "%{A1:"dunstctl set-paused false" && polybar-msg hook dunst 1:}п‡¶%{A}" &

[module/spotify]
type = custom/script
interval = 1
format-prefix = "п†ј "
format = <label>
exec = python ~/.config/polybar/scripts/spotify_status.py -f '{artist}: {song}'

[module/xkeyboard]
type = internal/xkeyboard
format = п„њ <label-layout><label-indicator>
format-foreground = ${colors.fg}

label-layout = %icon%

layout-icon-default = some-icon
layout-icon-0 = us;US
layout-icon-1 = ru;RU
layout-icon-2 = ua;UA

;label-indicator-on = %icon%
;label-indicator-off = %icon%

label-indicator-on-capslock = " п…‘"
label-indicator-off-capslock = ""
label-indicator-on-numlock = " пѓ‹" 
label-indicator-off-numlock = ""

[module/i3]
type = internal/i3
strip-wsnumbers = true
index-sort = true
enable-scroll = false
wrapping-scroll = false
reverse-scroll = false
fuzzy-match = true

format = <label-state><label-mode>
format-foreground = ${colors.fg}

label-mode = %mode%
;label-mode-padding = 2
label-mode-foreground = ${colors.fg}
label-mode-background = ${colors.bg}
 
label-focused = %name%
label-focused-foreground = ${colors.shade-5}
label-focused-background = ${colors.shade-1}
label-focused-padding = 1

label-unfocused = %name%
label-unfocused-foreground = ${colors.shade-3}
label-unfocused-padding = 1

label-visible = %name%
label-visible-background = ${colors.shade-1}
label-visible-underline = ${colors.red} 
label-visible-padding = 1

label-urgent = %name%
label-urgent-foreground = ${colors.shade-3}
label-urgent-background = ${colors.red}
label-urgent-padding = 1

[module/wlan]
type = internal/network
interface = wlp3s0f0
interval = 1.0

format-connected = <label-connected>
;format-connected-padding = 1
label-connected = %{A1:sh $HOME/.config/rofi/bin/network.sh:}п‡« %essid%%{A}
label-connected-foreground = ${colors.fg}
;label-connected-padding = 1

format-disconnected = <label-disconnected>
;format-disconnected-padding = 1
label-disconnected = %{A1:$HOME/.config/rofi/bin/network.sh:}пЄ©%{A}
label-disconnected-foreground = ${colors.shade-1}
;label-disconnected-padding = 1

[module/wlan2]
type = internal/network
interface = wlp3s0f0
;interface = wlan0
interval = 1.0
;udspeed-minwidth = 5
accumulate-stats = true
unknown-as-up = true

;format-connected = <label-connected>
format-connected = <ramp-signal><label-connected>
;format-connected-prefix = "WiFi "
;format-connected-prefix-foreground = ${colors.fg}

format-disconnected = <label-disconnected>

format-packetloss = <label-connected>

label-connected = %{A1:$HOME/.config/rofi/bin/network.sh:}%signal%% %essid%%{A}
label-connected-foreground = ${colors.fg}

label-disconnected = %{A1:$HOME/.config/rofi/bin/network.sh:}пЄ©%{A}
label-disconnected-foreground = ${colors.shade-1}

; Only applies if <ramp-signal> is used
ramp-signal-0 = "п®™ "
;ramp-signal-0 = "пЄЁ"
ramp-signal-0-foreground = #FF0000
 
ramp-signal-1 = "п›· "
;ramp-signal-1 = "пЄЁ"
 
ramp-signal-2 = "п›µ "
;ramp-signal-2 = "пЄЁ"
 
ramp-signal-3 = "п›ґ "
