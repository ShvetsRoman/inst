[module/eth]
type = internal/network
interface = enp2s0
interval = 3.0

format-connected-prefix = "п›ї "
format-connected-prefix-foreground = ${colors.fg-alt}
label-connected = %local_ip%

format-disconnected =

[module/date]
type = internal/date
interval = 1

;date = "%d.%m.%Y"
time = " %H:%M"

format = <label>
format-foreground = ${colors.fg}

;label = %{A1:$HOME/.config/rofi/bin/time.sh:}пЃі %date% пЂ—%time%%{A}
